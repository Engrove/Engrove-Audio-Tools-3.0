{
  "name": "engrove-audio-tools-3.0",
  "private": true,
  "version": "3.0.0-rc.5",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && node tools/generate-seo-files.mjs && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "tsc --noEmit",
    "check:tonearm": "node tools/check-tonearm-match-lab.mjs",
    "validate:data": "node tools/validate-audio-data.mjs",
    "check:data": "node tools/validate-audio-data.mjs",
    "check:integrity": "node tools/check-repo-integrity.mjs",
    "check:render-safe": "node tools/check-render-safe.mjs",
    "check:tonearm-selectors": "node tools/check-tonearm-runtime-selectors.mjs",
    "check:ui-doctrine": "node tools/check-ui-doctrine.mjs",
    "check:measurement-lab": "node tools/check-measurement-lab.mjs",
    "check:korf-geometry": "node tools/check-korf-geometry.mjs",
    "check:sanitation": "npm run check && npm run check:ui-doctrine && npm run check:integrity && npm run check:render-safe && npm run check:tonearm && npm run check:tonearm-selectors && npm run validate:data && npm run check:measurement-lab && npm run check:korf-geometry",
    "check:tokens-layout": "node tools/check-token-layout-drift.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
